# Image generation is proxied through pollinations.ai (free, keyless).
# The server proxy is required because pollinations.ai gates browser-origin
# requests with Cloudflare Turnstile; server-side calls are exempt.
# No API key is needed.

# Port the server listens on. Optional — defaults to 8080.
# Hosts like Render / Heroku / Fly inject this automatically.
PORT=

# Allowed CORS origins for the API. Optional — if unset, all origins are allowed.
# Comma-separated list. Set this in production to lock the API down to your client.
# Example: CORS_ORIGIN=https://devswag.app,https://www.devswag.app
CORS_ORIGIN=

# Rate limit window for POST /api/v1/image, in ms. Optional — defaults to 60000 (1 minute).
RATE_LIMIT_WINDOW_MS=

# Max requests per IP per window for POST /api/v1/image. Optional — defaults to 5.
RATE_LIMIT_MAX=

# Trust proxy hops in front of the server. Optional — leave unset for direct dev.
# Set to "1" when deployed behind a single proxy (Render, Heroku, Fly, Cloudflare),
# otherwise the rate limiter will see the proxy IP instead of the real client IP.
TRUST_PROXY=
