# OpenAI API key — required for the DALL·E proxy at POST /api/v1/dalle
OPENAI_API_KEY=

# Port the server listens on. Optional — defaults to 8080.
# Hosts like Render / Heroku / Fly inject this automatically.
PORT=

# Allowed CORS origins for the API. Optional — if unset, all origins are allowed.
# Comma-separated list. Set this in production to lock the API down to your client.
# Example: CORS_ORIGIN=https://devswag.app,https://www.devswag.app
CORS_ORIGIN=

# Rate limit window for POST /api/v1/dalle, in ms. Optional — defaults to 60000 (1 minute).
RATE_LIMIT_WINDOW_MS=

# Max requests per IP per window for POST /api/v1/dalle. Optional — defaults to 5.
# Each call hits gpt-image-1 and costs money, so keep this conservative.
RATE_LIMIT_MAX=

# Trust proxy hops in front of the server. Optional — leave unset for direct dev.
# Set to "1" when deployed behind a single proxy (Render, Heroku, Fly, Cloudflare),
# otherwise the rate limiter will see the proxy IP instead of the real client IP.
TRUST_PROXY=

# MongoDB connection string. Optional — if unset, /api/v1/designs (save/share) is
# disabled and the rest of the API still runs. MongoDB Atlas free tier works.
# Example: MONGO_URI=mongodb+srv://user:pass@cluster0.mongodb.net/shirts
MONGO_URI=

# Cloudinary credentials. Required only if MONGO_URI is set AND users save designs
# with custom (uploaded / AI-generated / text) decals. The free tier is plenty.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
